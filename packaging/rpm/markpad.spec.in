Name:           markpad
Version:        @VERSION@
Release:        1%{?dist}
Summary:        Lightweight GTK3 markdown editor/viewer

License:        MIT
URL:            @URL@
Source0:        markpad-%{version}.tar.gz

BuildRequires:  gcc
BuildRequires:  make
BuildRequires:  pkgconfig
BuildRequires:  gtk3-devel

Requires:       gtk3

%description
MarkPad is a lightweight native GTK3 markdown editor and viewer.

%prep
%autosetup -n markpad-%{version}

%build
make %{?_smp_mflags}

%install
rm -rf %{buildroot}
make install DESTDIR=%{buildroot} PREFIX=%{_prefix}

%files
%{_bindir}/markpad
%{_datadir}/applications/markpad.desktop

%changelog
* Thu Jan 01 1970 MarkPad Packager <noreply@example.com> - @VERSION@-1
- Initial package
